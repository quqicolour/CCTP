# CCTP 脚本环境变量

# 目标链 RPC
RPC_URL=https://mainnet.infura.io/v3/YOUR_INFURA_KEY
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY

# 部署者私钥（不要泄露！）
SEPOLIA_PRIVATE_KEY=0x...

# 已部署的 CCTPV2Core 地址
CCTP_CONTRACT=0x...

# 跨链参数
MESSAGE_HASH=0x...          # 消息哈希（Send 事件中的 topics[1]）
DESTINATION_DOMAIN=6        # Base = 6, Arbitrum = 3, Optimism = 2
MINT_RECIPIENT=0x...       # 目标链接收地址（bytes32 格式）

# 源链 USDC 地址
SOURCE_USDC=0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48
